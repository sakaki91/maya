#!/bin/bash

MAYA_VERSION=0.7
MAYA_TREE="$HOME/.local/share/maya"
MAYA_TMP="/tmp/maya"
[[ ! -d "$MAYA_TREE/pkg/info" ]] && mkdir -p "$MAYA_TREE/pkg/info"
[[ ! -d "$MAYA_TMP" ]] && mkdir -p "$MAYA_TMP"

function validateDependencies(){
    if [[ ! -z $DEPENDENCIES ]]; then
        for dep in "${DEPENDENCIES[@]}"; do
            if ! command -v "$dep" >/dev/null 2>&1; then
                printf "\e[0;91merror:\033[0m $dep is not installed.\n" && exit
            fi
        done
    fi
}

function validateBinaries(){
    [[ -z $1 ]] && printf "\e[0;91merror:\e[0m empty value.\n" && exit
    [[ ! -f "$MAYA_TREE/pkg/$1" ]] && printf "\e[0;91merror:\e[0m the package does not exist.\n" && exit
}

case $1 in
    "--help"|"-h")
        printf "\e[1moperations:\e[0m\n%-25s %0s\n" " -h  | --help" ":: show this message."
        printf "%-25s %0s\n" " -v  | --version" ":: shows the version."
        printf "%-25s %0s\n" " -a  | --about" ":: view the metadata (version, name, and description) of a package."
        printf "%-25s %0s\n" " -l  | --list" ":: shows all binaries available for installation."
        printf "%-25s %0s\n" " -li | --list-installed" ":: it shows everything that maya has installed."
        printf "%-25s %0s\n" " -cl | --clean" ":: clears the $MAYA_TMP directory."
        printf "%-25s %0s\n" " -sy | --sync-maya" ":: update maya and recipes by pulling directly from the git."
        printf "%-25s %0s\n" " -in | --install" ":: install a binary."
        printf "%-25s %0s\n\n" " -rm | --remove" ":: remove a binary."
        printf "\e[1musage: maya 'operation' [...]\e[0m\n"
    ;;
    "--version"|"-v") printf "maya-$MAYA_VERSION\n" ;;
    "--about"|"-a") 
        validateBinaries "$2"
        source "$MAYA_TREE/pkg/$2" && printf "\e[1m%-25s\e[0m %10s\n" "$NAME :: $VERSION" "$DESCRIPTION"
    ;;
    "--list"|"-l")
        [[ -z $2 ]] && printf "\e[0;95m$(ls $MAYA_TREE/pkg -p -1 | grep -v /)\e[0m\n" && exit
        [[ ! -z $2 ]] && printf "\e[0;95m$(ls $MAYA_TREE/pkg -p -1 | grep -v / | grep $2)\e[0m\n" && exit
    ;;
    "--list-installed"|"-li") printf "\e[0;92m$(ls $MAYA_TREE/pkg/info -p -1)\e[0m\n" ;;
    "--clean"|"-cl") sudo rm -rf "$MAYA_TMP" ;;
    "--sync-maya"|"-sy")
        [[ ! $(command -v git) ]] && printf "\e[0;91merror:\e[0m git not found\n." && exit
        (cd $MAYA_TREE && git pull)
    ;;
    "--install"|"-in")
        validateBinaries "$2"
        source "$MAYA_TREE/pkg/$2" && validateDependencies && install && touch "$MAYA_TREE/pkg/info/$NAME"
    ;;
    "--remove"|"-rm")
        validateBinaries "$2"
        source "$MAYA_TREE/pkg/$2" && remove && rm -f "$MAYA_TREE/pkg/info/$NAME"
    ;;
    *) printf "\e[0;93m::\e[0m usage: \e[1mmaya --help\e[0m\n" ;;
esac