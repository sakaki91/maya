#!/bin/bash

# ESTE SOFTWARE ATUALMENTE ESTÁ EM ESTADO INICIAL DE DESENVOLVIMENTO, NÃO É RECOMENDADO O USO.
# RECOMENDO O USO APENAS PARA FINS DE CONTRIBUIÇÃO, ESTUDOS E DEBUGGING.
 
MAYA_VERSION=0.2
MAYA_TREE="$HOME/.local/share/maya"

case $1 in
    "--help")
        printf "\n%-20s %0s\n" "--help" "show this message."
        printf "%-20s %0s\n\n" "--version" "shows the version."
        printf "%-20s %0s\n" "--list-installed" "it shows everything that maya has installed."
        printf "%-20s %0s\n" "--install" "install something."
        printf "%-20s %0s\n\n" "--remove" "remove something."
    ;;
    "--version") printf "maya-$MAYA_VERSION\n" ;;
    "--list-installed") ls $MAYA_TREE/pkg/info --color=no ;;
    "--install")
        [[ ! -f "$MAYA_TREE/pkg/$2" ]] && printf "\e[0;91merror:\e[0m the package does not exist.\n" && exit
        source "$MAYA_TREE/pkg/$2"
        install
        touch "$MAYA_TREE/pkg/info/$NAME"
    ;;
    "--remove")
        [[ ! -f "$MAYA_TREE/pkg/$2" ]] && printf "\e[0;91merror:\e[0m the package does not exist.\n" && exit
        source "$MAYA_TREE/pkg/$2"
        remove
        rm -f "$MAYA_TREE/pkg/info/$NAME"
    ;;
    *)
        printf ":: lost? type: \e[1mmaya --help\e[0m\n"
    ;;
esac