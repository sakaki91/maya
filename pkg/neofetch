#!/bin/bash

NAME="neofetch"
VERSION="7.0.1"
DESCRIPTION="A command-line system information tool written in bash 3.2+"
SOURCE="https://github.com/dylanaraps/neofetch"
DEPENDENCIES=(
	"git"
)

function install(){
    git clone $SOURCE /tmp/maya/$NAME
    /usr/bin/install /tmp/maya/$NAME/$NAME /usr/bin/$NAME
}

function remove(){
	rm -rf /bin/$NAME "$MAYA_TMP/$NAME"
}
